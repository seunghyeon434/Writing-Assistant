{
  "manifest_version": 3,
  "name": "Writing Assistant Bridge",
  "version": "0.1.0",
  "description": "Connects browser text fields to the local Writing Assistant app.",
  "permissions": ["activeTab", "clipboardWrite"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8766/*"],
  "action": {
    "default_title": "Writing Assistant",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
