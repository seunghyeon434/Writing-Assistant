DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ai_grammary
# Copy this file to .env and fill in real values.
#
# SECRET_KEY must be a long random string. Keep it private.
SECRET_KEY=replace-with-a-random-string-longer-than-100-characters

# Put a newly issued OpenAI API key here.
# Do not commit or share real API keys.
OPENAI_API_KEY=sk-your-openai-api-key

